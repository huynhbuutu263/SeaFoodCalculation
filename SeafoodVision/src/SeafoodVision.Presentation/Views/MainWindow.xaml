<Window x:Class="SeafoodVision.Presentation.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SeafoodVision – Real-Time Counting" Height="600" Width="900"
        Background="#1E1E2E">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="4"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="🐟 SeafoodVision" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding StatusMessage}" Margin="16,0,0,0"
                       Foreground="#A0A0B0" VerticalAlignment="Center" FontSize="14"/>
        </StackPanel>

        <!-- Live Count Display -->
        <Border Grid.Row="1" Background="#2D2D3F" CornerRadius="8" Padding="24">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="TOTAL COUNT" FontSize="16" HorizontalAlignment="Center"
                           Foreground="#A0A0B0" LetterSpacing="4"/>
                <TextBlock Text="{Binding CurrentCount}" FontSize="96" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="#7DF9A0"/>
                <TextBlock Text="{Binding CurrentSession.CameraId, StringFormat='Camera: {0}', FallbackValue='No active session'}"
                           FontSize="14" HorizontalAlignment="Center" Foreground="#A0A0B0" Margin="0,8,0,0"/>
            </StackPanel>
        </Border>

        <!-- Control Bar -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0">
            <Button Content="▶  Start" Command="{Binding StartCommand}"
                    Background="#4CAF50" Foreground="White"/>
            <Button Content="⏹  Stop" Command="{Binding StopCommand}"
                    Background="#F44336" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>
