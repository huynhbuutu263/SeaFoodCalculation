<Window x:Class="SeafoodVision.Presentation.Views.RoiDrawingDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:SeafoodVision.Presentation.Controls"
        xmlns:viewmodels="clr-namespace:SeafoodVision.Presentation.ViewModels"
        xmlns:converters="clr-namespace:SeafoodVision.Presentation.Converters"
        mc:Ignorable="d"
        Title="Draw Region of Interest (ROI)" Height="650" Width="950"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResizeWithGrip"
        d:DataContext="{d:DesignInstance Type=viewmodels:RoiDrawingViewModel, IsDesignTimeCreatable=False}">
    
    <Window.Resources>
        <converters:EnumToBooleanConverter x:Key="EnumToBoolConverter" />
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top Controls: ROI Name & Help text -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="ROI Name: " VerticalAlignment="Center" FontWeight="Bold"/>
            <TextBox Text="{Binding RoiName, UpdateSourceTrigger=PropertyChanged}" 
                     Width="200" Margin="5,0,20,0" Padding="2" VerticalContentAlignment="Center"/>
            <TextBlock Text="Tip: Trace the item contour. Drag for Rectangles. Click for Polygons; double-click to close." 
                       VerticalAlignment="Center" FontStyle="Italic" Foreground="Gray"/>
        </StackPanel>

        <!-- Toolbar: Shape Modes & Clear -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Shape Mode:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                
                <RadioButton Content="Rectangle" Margin="0,0,15,0" VerticalAlignment="Center"
                             IsChecked="{Binding ActiveShapeType, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Rectangle}"/>
                
                <RadioButton Content="Polygon" Margin="0,0,15,0" VerticalAlignment="Center"
                             IsChecked="{Binding ActiveShapeType, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Polygon}"/>
                
                <Button Content="🗑 Clear Shape" Command="{Binding ClearCommand}" 
                        Padding="10,4" Margin="30,0,0,0" Background="#fdd"/>
            </StackPanel>
        </Grid>

        <!-- Main Canvas Area -->
        <Border Grid.Row="2" BorderBrush="DarkGray" BorderThickness="1" Background="Black">
            <!-- Grid forces RoiCanvas to identically overlay Image on all edges -->
            <Grid ClipToBounds="True">
                <Image Source="{Binding ReferenceFrame}" Stretch="Uniform" />
                <controls:RoiCanvas 
                    Region="{Binding Region, Mode=TwoWay}"
                    ActiveShapeType="{Binding ActiveShapeType}" />
            </Grid>
        </Border>

        <!-- Dialog Action Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Cancel" Command="{Binding CancelCommand}" 
                    Width="100" Padding="8" Margin="0,0,10,0"/>
            
            <Button Content="💾 Confirm Region" Command="{Binding ConfirmCommand}" 
                    Width="120" Padding="8" Background="#ddf" FontWeight="SemiBold"/>
        </StackPanel>
    </Grid>
</Window>
