<Window x:Class="SeafoodVision.Presentation.Views.VisionConfigDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewmodels="clr-namespace:SeafoodVision.Presentation.ViewModels"
        xmlns:params="clr-namespace:SeafoodVision.Inspection.Pipeline.Models;assembly=SeafoodVision.Inspection"
        mc:Ignorable="d"
        Title="Vision Execution Pipeline Configurator" Height="700" Width="1100"
        WindowStartupLocation="CenterOwner"
        d:DataContext="{d:DesignInstance Type=viewmodels:VisionConfigViewModel, IsDesignTimeCreatable=False}">

    <Window.Resources>
        <!-- DataTemplate for ThresholdParams -->
        <DataTemplate DataType="{x:Type params:ThresholdParams}">
            <StackPanel Margin="10">
                <TextBlock Text="Threshold Value:" FontWeight="Bold" Margin="0,0,0,5"/>
                <Slider Minimum="0" Maximum="255" Value="{Binding ThreshValue, UpdateSourceTrigger=PropertyChanged}" 
                        TickFrequency="1" IsSnapToTickEnabled="True" Margin="0,0,0,5"/>
                <TextBlock Text="{Binding ThreshValue}" HorizontalAlignment="Right" Margin="0,0,0,15"/>

                <TextBlock Text="Max Value:" FontWeight="Bold" Margin="0,0,0,5"/>
                <Slider Minimum="0" Maximum="255" Value="{Binding MaxValue, UpdateSourceTrigger=PropertyChanged}"
                        TickFrequency="1" IsSnapToTickEnabled="True" Margin="0,0,0,5"/>
                <TextBlock Text="{Binding MaxValue}" HorizontalAlignment="Right" Margin="0,0,0,15"/>
            </StackPanel>
        </DataTemplate>

        <!-- DataTemplate for GaussianBlurParams -->
        <DataTemplate DataType="{x:Type params:GaussianBlurParams}">
            <StackPanel Margin="10">
                <TextBlock Text="Kernel Width (Odd number):" FontWeight="Bold" Margin="0,0,0,5"/>
                <Slider Minimum="1" Maximum="31" Value="{Binding KernelWidth, UpdateSourceTrigger=PropertyChanged}" 
                        TickFrequency="2" IsSnapToTickEnabled="True" Margin="0,0,0,5"/>
                <TextBlock Text="{Binding KernelWidth}" HorizontalAlignment="Right" Margin="0,0,0,15"/>
                
                <TextBlock Text="Kernel Height (Odd number):" FontWeight="Bold" Margin="0,0,0,5"/>
                <Slider Minimum="1" Maximum="31" Value="{Binding KernelHeight, UpdateSourceTrigger=PropertyChanged}" 
                        TickFrequency="2" IsSnapToTickEnabled="True" Margin="0,0,0,5"/>
                <TextBlock Text="{Binding KernelHeight}" HorizontalAlignment="Right" Margin="0,0,0,15"/>
            </StackPanel>
        </DataTemplate>

        <!-- DataTemplate for MorphologyParams -->
        <DataTemplate DataType="{x:Type params:MorphologyParams}">
            <StackPanel Margin="10">
                <TextBlock Text="Kernel Size:" FontWeight="Bold" Margin="0,0,0,5"/>
                <Slider Minimum="1" Maximum="21" Value="{Binding KernelSize, UpdateSourceTrigger=PropertyChanged}" 
                        TickFrequency="1" IsSnapToTickEnabled="True" Margin="0,0,0,5"/>
                <TextBlock Text="{Binding KernelSize}" HorizontalAlignment="Right" Margin="0,0,0,15"/>

                <TextBlock Text="Iterations:" FontWeight="Bold" Margin="0,0,0,5"/>
                <Slider Minimum="1" Maximum="10" Value="{Binding Iterations, UpdateSourceTrigger=PropertyChanged}" 
                        TickFrequency="1" IsSnapToTickEnabled="True" Margin="0,0,0,5"/>
                <TextBlock Text="{Binding Iterations}" HorizontalAlignment="Right" Margin="0,0,0,15"/>
            </StackPanel>
        </DataTemplate>

        <!-- Generic string formatting for Step Items -->
        <DataTemplate DataType="{x:Type viewmodels:VisionStepViewModel}">
            <TextBlock Text="{Binding Name}" Padding="5"/>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT PANEL: Step Sequence -->
        <Grid Grid.Column="0" Margin="0,0,10,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Execution Steps" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
            
            <ListBox Grid.Row="1" ItemsSource="{Binding Steps}" 
                     SelectedItem="{Binding SelectedStep, Mode=TwoWay}"
                     BorderBrush="Gray" BorderThickness="1">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⇒" Foreground="Gray" Margin="0,0,5,0"/>
                            <TextBlock Text="{Binding Name}" FontSize="13" VerticalAlignment="Center" Padding="0,3"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <StackPanel Grid.Row="2" Margin="0,5,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,5">
                    <ComboBox ItemsSource="{Binding AvailableStepTypes}" 
                              SelectedItem="{Binding SelectedNewStepType, Mode=TwoWay}" 
                              Width="140" Margin="0,0,5,0" VerticalContentAlignment="Center"/>
                    <Button Content="➕ Add" Command="{Binding AddStepCommand}" Width="50" Padding="2"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="➖ Del" Command="{Binding RemoveCommand}" Width="60" Margin="2" Padding="2"/>
                    <Button Content="⬆ Up" Command="{Binding MoveUpCommand}" Width="60" Margin="2" Padding="2"/>
                    <Button Content="⬇ Dn" Command="{Binding MoveDownCommand}" Width="60" Margin="2" Padding="2"/>
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- MIDDLE PANEL: Parameter Editor -->
        <Border Grid.Column="1" BorderBrush="LightGray" BorderThickness="1" Margin="0,0,10,0" Padding="5">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <TextBlock Grid.Row="0" Text="Step Parameters" FontWeight="Bold" FontSize="14" Margin="0,0,0,10" Padding="5"/>
                
                <ContentControl Grid.Row="1" Content="{Binding SelectedStep.Parameters}"/>
                
                <TextBlock Grid.Row="1" Text="(Select a Step. Note: Some advanced parameter templates may not be rendered in this view yet.)" 
                           Foreground="DarkGray" TextWrapping="Wrap" Margin="10" FontStyle="Italic"
                           VerticalAlignment="Bottom"/>
            </Grid>
        </Border>

        <!-- RIGHT PANEL: Live Pipeline Preview -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Live Result Preview (Up to selected step)" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
            
            <Border Grid.Row="1" BorderBrush="#333" BorderThickness="2" Background="Black">
                <Image Source="{Binding PreviewFrame}" Stretch="Uniform" />
            </Border>
        </Grid>
    </Grid>
</Window>
